# Build output.
# NOTE: /dist is intentionally committed (see README "Install"). pnpm 10.26+
# blocks a git dependency's `prepare` build script unless the consumer
# allowlists it, so shipping a prebuilt dist is what makes
# `pnpm add github:lukasedw/bobina` work with no extra config.
/out-tsc
/tmp

# Dependencies
/node_modules
/.pnp
.pnp.js

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
/coverage

# Editor / OS
.vscode/*
.idea
.DS_Store
